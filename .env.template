STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=
DB_NAME=medusa-v2

# Google OAuth (optional). Leave blank to disable Google sign-in. When all three
# are set, the auth module registers the @medusajs/auth-google provider.
# callbackUrl must be a frontend URL — Google redirects users there with a
# `code` query param, which the storefront then sends to Medusa to validate.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://shop.dollupboutique.com/auth/google/callback

# Resend transactional email (optional). When both API_KEY + FROM_EMAIL are set,
# the notification-resend provider registers and emails fire on:
#   order.placed, customer.created, auth.password_reset, dm.order.shipped
# Skip these vars to keep email disabled — backend boots cleanly either way.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@dollupboutique.com
RESEND_FROM_NAME=Doll Up Team
RESEND_REPLY_TO=hello@dollupboutique.com

# Storefront URL used in email links + logo. Override per environment.
STOREFRONT_URL=https://shop.dollupboutique.com
