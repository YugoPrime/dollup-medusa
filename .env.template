STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=
DB_NAME=medusa-v2

# Google OAuth (optional). Leave blank to disable Google sign-in. When all three
# are set, the auth module registers the @medusajs/auth-google provider.
# callbackUrl must be a frontend URL — Google redirects users there with a
# `code` query param, which the storefront then sends to Medusa to validate.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://shop.dollupboutique.com/auth/google/callback

# Resend transactional email (optional). When both API_KEY + FROM_EMAIL are set,
# the notification-resend provider registers and emails fire on:
#   order.placed, customer.created, auth.password_reset, dm.order.shipped
# Skip these vars to keep email disabled — backend boots cleanly either way.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@dollupboutique.com
RESEND_FROM_NAME=Doll Up Team
RESEND_REPLY_TO=hello@dollupboutique.com

# Storefront URL used in email links + logo. Override per environment.
STOREFRONT_URL=https://shop.dollupboutique.com

# R2 (used by sourcing module image uploads). Same credentials as inventory-audit/.env.local.
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_URL=

# Meta unified inbox (chat module) — see docs/superpowers/specs/2026-05-09-unified-inbox-design.md
META_APP_SECRET=
META_MESSENGER_VERIFY_TOKEN=
META_GRAPH_VERSION=v20.0
CHAT_MODULE_ENABLED=false

# FB Page Story cross-post (optional)
# When STORIES_CROSSPOST_FB=true and META_FB_PAGE_ID is set, the auto-pilot
# also posts each successful IG story as a FB Page video story.
# Uses the same META_PAGE_ACCESS_TOKEN; needs pages_manage_posts scope.
META_FB_PAGE_ID=
STORIES_CROSSPOST_FB=

# Telegram notifications. Used by:
#   - create-tomorrow-plan cron (18:00 MU): summary every run
#   - publish-due-stories cron: alert when a slot hits MAX_ATTEMPTS=3 fails
#   - publish-story-slot: alert when FB cross-post fails but IG succeeded
#   - cleanup-story-renders cron (03:30 MU): summary when deletes occurred
#   - local-render-stories (PM2 cron on laptop): summary every render run
# Wiring test: yarn medusa exec ./src/scripts/test-telegram.ts
# NOTE: the laptop's PM2 render daemon needs these in .env.local-render too —
# Coolify env is separate from the laptop environment.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Daily R2 cleanup of old story MP4s (cron: 03:30 MU). Kill-switch + dry-run
# preview. Recommend STORIES_R2_CLEANUP_DRY_RUN=true for the first night so
# the Telegram summary tells you what WOULD be deleted before flipping live.
STORIES_R2_CLEANUP_ENABLED=
STORIES_R2_CLEANUP_DRY_RUN=
