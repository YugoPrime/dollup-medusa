{
  "slug": "customer-review",
  "name": "Customer Review",
  "category": "editorial",
  "duration_seconds": 6,
  "wave": 1,
  "slots": [
    {
      "id": "product_photo",
      "hint": "lifestyle",
      "label": "Product or lifestyle photo (full-bleed)",
      "required": true
    }
  ],
  "text_overrides": [
    {
      "id": "stars",
      "default": "★ ★ ★ ★ ★",
      "max_chars": 12
    },
    {
      "id": "quote",
      "default": "Absolutely love it - fits perfectly and the fabric is gorgeous!",
      "max_chars": 140
    },
    {
      "id": "reviewer",
      "default": "- Anna M.",
      "max_chars": 28
    },
    {
      "id": "product_name",
      "default": "Babe Essentials",
      "max_chars": 28
    },
    {
      "id": "footer",
      "default": "DM to ORDER",
      "max_chars": 20
    },
    {
      "id": "footer_url",
      "default": "shop dollupboutique.com",
      "max_chars": 32
    }
  ]
}
