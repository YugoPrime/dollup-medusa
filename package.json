{
  "name": "medusa-starter-default",
  "version": "0.0.1",
  "packageManager": "yarn@4.12.0",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "setup:shipping": "medusa exec ./src/scripts/setup-shipping.ts",
    "check:ids": "medusa exec ./src/scripts/check-ids.ts",
    "import:customers": "medusa exec ./src/scripts/import-woo-customers.ts",
    "import:customers:dry": "WOO_IMPORT_DRY_RUN=1 medusa exec ./src/scripts/import-woo-customers.ts",
    "seed:starter-dangerous": "medusa exec ./src/scripts/_DO_NOT_RUN_starter-seed-europe.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "regen-previews": "ts-node src/scripts/regen-template-previews.ts",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "email:dev": "email dev --dir src/modules/notification-resend/templates/previews --port 3030"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@googleapis/sheets": "^13.0.1",
    "@medusajs/admin-sdk": "2.13.1",
    "@medusajs/auth-google": "2.13.1",
    "@medusajs/cli": "2.13.1",
    "@medusajs/event-bus-redis": "2.13.1",
    "@medusajs/framework": "2.13.1",
    "@medusajs/fulfillment-manual": "2.13.1",
    "@medusajs/locking": "2.13.1",
    "@medusajs/locking-redis": "2.13.1",
    "@medusajs/medusa": "2.13.1",
    "@medusajs/payment": "2.13.1",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "cheerio": "^1.2.0",
    "google-auth-library": "^10.6.2",
    "hyperframes": "^0.6.6",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@imgly/background-removal-node": "^1.4.5",
    "@medusajs/test-utils": "2.13.1",
    "@react-email/ui": "6.1.1",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-email": "^6.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=22"
  }
}
